---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const enPosts  = allPosts.filter(p => p.data.lang === 'en').sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const esPosts  = allPosts.filter(p => p.data.lang === 'es').sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="Blog" description="Insights for physician content creators.">
    <Nav />
    <div class="page">

        <div style="margin-bottom:48px; padding-bottom:32px; border-bottom:1px solid var(--gray-100);">
            <h1 class="h1" style="margin-bottom:8px;">The Signal Blog</h1>
            <p class="muted" style="font-size:14px;">For physicians who create content that matters.</p>
        </div>

        <!-- ENGLISH POSTS -->
        <div style="margin-bottom:56px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
                <span class="label">In English</span>
                <div style="flex:1; height:1px; background:var(--gray-100);"></div>
            </div>
            <div style="display:grid; gap:16px;">
                {enPosts.map(post => (
                    <a href={`/blog/${post.slug}`} style="text-decoration:none;">
                        <div class="card" style="transition:box-shadow 0.2s; cursor:pointer;" onmouseover="this.style.boxShadow='var(--shadow-md)'" onmouseout="this.style.boxShadow=''">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:20px;">
                                <div>
                                    {post.data.specialty && <span class="badge badge-indigo" style="margin-bottom:10px;">{post.data.specialty}</span>}
                                    <h2 class="h3" style="margin-bottom:8px; color:var(--black);">{post.data.title}</h2>
                                    <p class="muted" style="font-size:13px; line-height:1.6;">{post.data.description}</p>
                                </div>
                                <span style="color:var(--gray-300); font-size:20px; flex-shrink:0; margin-top:4px;">→</span>
                            </div>
                            <div style="margin-top:14px; font-size:12px; color:var(--gray-300);">
                                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        <!-- SPANISH POSTS -->
        <div>
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
                <span class="label">En Español</span>
                <div style="flex:1; height:1px; background:var(--gray-100);"></div>
            </div>
            <div style="display:grid; gap:16px;">
                {esPosts.map(post => (
                    <a href={`/blog/${post.slug}`} style="text-decoration:none;">
                        <div class="card" style="transition:box-shadow 0.2s; cursor:pointer;" onmouseover="this.style.boxShadow='var(--shadow-md)'" onmouseout="this.style.boxShadow=''">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:20px;">
                                <div>
                                    {post.data.specialty && <span class="badge badge-indigo" style="margin-bottom:10px;">{post.data.specialty}</span>}
                                    <h2 class="h3" style="margin-bottom:8px; color:var(--black);">{post.data.title}</h2>
                                    <p class="muted" style="font-size:13px; line-height:1.6;">{post.data.description}</p>
                                </div>
                                <span style="color:var(--gray-300); font-size:20px; flex-shrink:0; margin-top:4px;">→</span>
                            </div>
                            <div style="margin-top:14px; font-size:12px; color:var(--gray-300);">
                                {post.data.pubDate.toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>

    </div>
</Base>
